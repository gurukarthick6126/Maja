datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  passwordHash     String
  name             String
  theme            String          @default("dark") // "light" | "dark"
  reminderTiming   Int             @default(2) // days before
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  projects         Project[]
  habits           Habit[]
  scheduledTasks   ScheduledTask[]
  notifications    Notification[]
  weeklyDebriefs   WeeklyDebrief[]
  sessions         Session[]
  monthlyReports   MonthlyReport[]
}

model MonthlyReport {
  id            String   @id @default(cuid())
  monthStart    String   // YYYY-MM
  summary       String
  trends        String   // JSON string of stats and insights
  generatedAt   DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthStart])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id         String   @id @default(cuid())
  name       String
  status     String   @default("planning") // "planning" | "in progress" | "done"
  deadline   DateTime?
  objective  String   @default("")
  result     String   @default("")
  lesson     String   @default("")
  compromise String   @default("")
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks      Task[]
  createdAt  DateTime @default(now())
}

model Task {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  status     String   @default("todo") // "todo" | "in progress" | "done"
  deadline   DateTime?
  priority   String   @default("medium") // "high" | "medium" | "low"
  aiReason   String   @default("")
  objective  String   @default("")
  result     String   @default("")
  lesson     String   @default("")
  compromise String   @default("")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Habit {
  id            String         @id @default(cuid())
  name          String
  streak        Int            @default(0)
  lastCheckedIn DateTime?
  objective     String         @default("")
  result        String         @default("")
  lesson        String         @default("")
  compromise    String         @default("")
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIns      HabitCheckIn[]
  createdAt     DateTime       @default(now())
}

model HabitCheckIn {
  id        String   @id @default(cuid())
  habitId   String
  date      String   // YYYY-MM-DD
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

model ScheduledTask {
  id         String   @id @default(cuid())
  name       String
  date       String   // YYYY-MM-DD
  time       String   // HH:MM
  objective  String   @default("")
  result     String   @default("")
  lesson     String   @default("")
  compromise String   @default("")
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // "deadline_project" | "deadline_task" | "scheduled_reminder"
  refId     String   // Project ID, Task ID, or ScheduledTask ID
  refType   String   // "project" | "task" | "scheduled"
  dueDate   DateTime
  title     String
  message   String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model WeeklyDebrief {
  id              String   @id @default(cuid())
  weekStart       String   // YYYY-MM-DD (Sunday)
  tasksCompleted  Int
  habitsKept      Int
  deadlinesHit    Int
  deadlinesMissed Int
  topLesson       String
  topResult       String
  summary         String
  generatedAt     DateTime @default(now())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}
